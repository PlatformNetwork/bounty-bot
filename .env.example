# Bounty Bot Configuration
# Copy to .env and fill in your values.

# ── Required — GitHub ──
GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret
TARGET_REPO=PlatformNetwork/bounty-challenge

# ── Required — Inter-service auth (must match Atlas) ──
INTER_SERVICE_HMAC_SECRET=your_shared_secret

# ── Required — LLM (OpenRouter) ──
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# ── Service ──
PORT=3235
DATA_DIR=/app/data
REDIS_URL=redis://redis:6379

# ── Atlas callback ──
ATLAS_WEBHOOK_URL=http://atlas:3230/webhooks

# ── Tuning (optional) ──
# ISSUE_FLOOR=41000
# SPAM_THRESHOLD=0.7
# DUPLICATE_THRESHOLD=0.75
# POLLER_INTERVAL=60000
# MAX_RETRIES=3
